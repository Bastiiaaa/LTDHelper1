<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <StartupObject>LTDHelper.SingleInstance</StartupObject>
    <RootNamespace>LTDHelper</RootNamespace>
    <AssemblyName>LTDHelper</AssemblyName>
    <Company>LTDHelper</Company>
    <Product>LTDHelper</Product>
    <AssemblyTitle>LTDHelper</AssemblyTitle>
    <Version>1.0.0.0</Version>
    <FileVersion>1.0.0.0</FileVersion>
    <InformationalVersion>1.0.0</InformationalVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="Geode">
      <HintPath>Geode.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>
</Project>